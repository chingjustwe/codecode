# ── Provider & API Key ──────────────────────────────────────────
# Choose LLM provider: anthropic (default) | claude | openai | deepseek | minimax | kimi
LLM_PROVIDER=anthropic

# Your API key (any of the following is fine)
# LLM_API_KEY=your_API_Key_here                  (general fallback)
ANTHROPIC_API_KEY=your_Anthropic_API_Key_here
# OPENAI_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
# MINIMAX_API_KEY=sk-xxx
# KIMI_API_KEY=sk-xxx

# ── Optional: specify model ──────────────────────────────────────
# LLM_MODEL=claude-sonnet-4-20250514